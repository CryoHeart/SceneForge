generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  fan
  band_admin
  venue_admin
  admin
}

model User {
  id          String       @id @default(cuid())
  username    String       @unique
  email       String       @unique
  password    String
  role        UserRole     @default(fan)
  bandId      String?
  venueId     String?
  band        Band?        @relation(fields: [bandId], references: [id])
  venue       Venue?       @relation(fields: [venueId], references: [id])
  savedEvents SavedEvent[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Band {
  id          String       @id @default(cuid())
  name        String
  bio         String       @db.Text
  genres      Json
  city        String
  imageUrl    String?
  socialLinks Json
  users       User[]
  events      EventBand[]
  setlists    Setlist[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Venue {
  id          String      @id @default(cuid())
  name        String
  city        String
  address     String
  capacity    Int
  description String      @db.Text
  users       User[]
  events      Event[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Event {
  id          String       @id @default(cuid())
  title       String
  city        String
  genre       String
  description String       @db.Text
  date        DateTime
  price       Decimal      @db.Decimal(8, 2)
  ticketUrl   String?
  venueId     String
  venue       Venue        @relation(fields: [venueId], references: [id])
  posters     Poster[]
  bands       EventBand[]
  setlists    Setlist[]
  savedBy     SavedEvent[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model EventBand {
  eventId  String
  bandId   String
  slotTime String?
  event    Event  @relation(fields: [eventId], references: [id])
  band     Band   @relation(fields: [bandId], references: [id])

  @@id([eventId, bandId])
}

model Poster {
  id        String   @id @default(cuid())
  imageUrl  String
  caption   String?
  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())
}

model Setlist {
  id        String   @id @default(cuid())
  eventId   String
  bandId    String
  songs     Json
  event     Event    @relation(fields: [eventId], references: [id])
  band      Band     @relation(fields: [bandId], references: [id])
  createdAt DateTime @default(now())
}

model SavedEvent {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}
